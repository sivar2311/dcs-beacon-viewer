{
  "name": "dcs-beacon-viewer",
  "version": "1.0.1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "nodemon -e js,html,css -x electron .",
    "build": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish onTag"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.github.sivar2311.dcs-beaconviewer",
    "productName": "DCS Beacon Viewer",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github"
    }
  }
}